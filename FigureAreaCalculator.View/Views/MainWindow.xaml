<Window x:Class="FigureAreaCalculator.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kalkulator pól figur" Height="350" Width="400">
    <StackPanel Margin="20">
        <TextBlock Text="Wybierz figurę: "/>
        <ComboBox ItemsSource="{Binding Figures}" SelectedItem="{Binding SelectedFigure}" Margin="0,5,0,15"/>
        <TextBlock Text="Parametr A: "/>
        <TextBox Text="{Binding ParameterA, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>
        <TextBlock Text="Parametr B: "/>
        <TextBox Text="{Binding ParameterB, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>
        <Button Content="Oblicz pole" Command="{Binding CalculateCommand}" Height="35"/>
        <TextBlock Text="{Binding Result}" Margin="0,20,0,0" FontWeight="Bold" TextWrapping="Wrap"/>
    </StackPanel>
</Window>
